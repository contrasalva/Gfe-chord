# Variables de entorno para Railway
# Copiar estas variables en Railway → Variables

NODE_ENV=production

# JWT - generá un string random largo y seguro
JWT_SECRET=your-super-secret-jwt-key-change-this

# Base de datos SQLite (Railway filesystem)
DATABASE_URL=file:/app/data/prod.db

# URL del cliente (se llena con el dominio que Railway asigne)
# Ejemplo: https://gfe-chord.up.railway.app
CLIENT_URL=https://your-app.up.railway.app
